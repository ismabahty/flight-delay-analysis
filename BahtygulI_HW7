        "#Crude Oil vs Gasoline:\n",
        "\n",
        "x1 = df['crude']\n",
        "y1 = df['gas']\n",
        "slope1, intercept1, r1, p1, se1 = stats.linregress(x1, y1)\n",
        "plt.figure(figsize=(8,5))\n",
        "plt.scatter(x1, y1, color='steelblue', label='Data points')\n",
        "plt.plot(x1, intercept1 + slope1*x1, color='red', label='Regression line')\n",
        "plt.title('Crude Oil Price vs Gasoline Price')\n",
        "plt.xlabel('Crude Oil Price ($/barrel)')\n",
        "plt.ylabel('Gasoline Price ($/gallon)')\n",
        "plt.legend()\n",
        "plt.show()\n",
        "print(f'r = {r1:.4f}')\n",
        "print(f'R2 = {r1**2:.4f}')\n",
        "print(f'y = {intercept1:.4f} + {slope1:.4f}x')\n"
